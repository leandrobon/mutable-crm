{
  "name": "mutable-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait",
    "db:init": "tsx --env-file=.env.local scripts/init-db.ts",
    "db:psql": "docker compose exec db psql -U mutable-crm -d mutable-crm",
    "test": "npm run test:migrations && npm run test:rows && npm run test:undo",
    "test:migrations": "tsx --env-file=.env.local --tsconfig tsconfig.json scripts/test-migrations.ts",
    "test:rows": "tsx --env-file=.env.local --tsconfig tsconfig.json scripts/test-rows.ts",
    "test:undo": "tsx --env-file=.env.local --tsconfig tsconfig.json scripts/test-undo.ts",
    "test:e2e": "tsx --env-file=.env.local --tsconfig tsconfig.json scripts/test-end-to-end.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
